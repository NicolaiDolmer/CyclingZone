VITE_SUPABASE_URL=https://example.supabase.co
VITE_SUPABASE_ANON_KEY=replace-me
VITE_API_URL=http://localhost:3001/api
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=0.1
# Google Analytics 4 measurement ID (G-XXXXXXXXXX). Only set in Vercel
# production — leave empty locally/in previews so dev traffic never pollutes
# the data. gtag.js loads only after analytics consent (see gaIntegration.jsx).
VITE_GA_MEASUREMENT_ID=
# Public base URL used as redirect target for password-reset emails.
# Defaults to https://cyclingzone.org if unset — set this in local dev
# to http://localhost:5173 if you want reset-links to come back to your dev server.
VITE_PUBLIC_APP_URL=https://cyclingzone.org
