{
  "name": "cycling-zone-manager",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "sync-docs": "node scripts/sync-docs.js",
    "check:patchnotes": "node scripts/check-patch-notes-version.js",
    "doctor": "pwsh -File scripts/agent-doctor.ps1",
    "codex:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/codex-session-start.ps1",
    "cleanup:worktrees": "pwsh -File scripts/prune-merged-worktrees.ps1",
    "cleanup:worktrees:run": "pwsh -File scripts/prune-merged-worktrees.ps1 -Execute",
    "race:cockpit": "pwsh -File scripts/race-cockpit.ps1",
    "check:warnings": "node scripts/check-eslint-warning-budget.mjs",
    "check:i18n": "node scripts/i18n-check-keys.mjs && node scripts/i18n-check-namespace-inline.mjs && node scripts/i18n-check-nav-strings.mjs && node scripts/i18n-check-page-untranslated.mjs && node scripts/i18n-check-lib-strings.mjs && node scripts/i18n-check-leaks.mjs && node --test scripts/tone-check-em-dash.test.mjs && node scripts/tone-check-em-dash.mjs && node --test scripts/i18n-check-icu-braces.test.mjs && node scripts/i18n-check-icu-braces.mjs",
    "check:i18n-leaks": "node scripts/i18n-check-leaks.mjs",
    "check:frontend-env": "node scripts/check-frontend-env-keys.mjs",
    "test:i18n-leaks": "node --test scripts/i18n-check-leaks.test.mjs",
    "test:tone-guard": "node --test scripts/tone-check-em-dash.test.mjs",
    "test:icu-braces": "node --test scripts/i18n-check-icu-braces.test.mjs",
    "brand:export": "node scripts/brand-export.mjs",
    "brand:export:og": "node scripts/brand-export.mjs og frontend/public/og-cycling-zone.svg frontend/public/og-cycling-zone.png",
    "brand:export:banner": "node scripts/brand-export.mjs banner frontend/public/brand/discord-banner.svg frontend/public/brand/discord-banner.png",
    "lint:sql": "node scripts/lint-sql-strings.mjs",
    "test:lint-sql": "node --test scripts/lint-sql-strings.test.mjs",
    "lint:migrations": "node scripts/lint-migration-idempotency.mjs",
    "test:lint-migrations": "node --test scripts/lint-migration-idempotency.test.mjs",
    "lint:ui-slop": "node scripts/lint-ui-slop.mjs",
    "test:lint-ui-slop": "node --test scripts/lint-ui-slop.test.mjs",
    "check:ui-slop-baseline": "node scripts/lint-ui-slop.mjs --update-baseline",
    "lint:postgrest-cap": "node scripts/lint-postgrest-in-cap.mjs",
    "test:lint-postgrest-cap": "node --test scripts/lint-postgrest-in-cap.test.mjs",
    "lint:getuser-guard": "node scripts/lint-getuser-guard.mjs",
    "test:lint-getuser-guard": "node --test scripts/lint-getuser-guard.test.mjs",
    "lint:rankings-fetch": "node scripts/lint-rankings-raceresults-fetch.mjs",
    "test:lint-rankings-fetch": "node --test scripts/lint-rankings-raceresults-fetch.test.mjs",
    "lint:riders-column-grant": "node scripts/lint-riders-column-grant.mjs",
    "test:lint-riders-column-grant": "node --test scripts/lint-riders-column-grant.test.mjs",
    "test:setup": "node scripts/setup-test-accounts.mjs",
    "test:smoke": "node scripts/smoke-test-prod.mjs",
    "test:token": "node scripts/get-test-token.mjs",
    "sync-deps": "npm ci && npm ci --prefix backend && npm ci --prefix frontend",
    "dev:backend": "npm --prefix backend run dev",
    "audit:rls": "infisical run --env=dev -- node backend/scripts/audit-rls-coverage.js",
    "audit:liveness": "infisical run --env=dev -- node backend/scripts/audit-feature-liveness.js",
    "audit:sentry": "infisical run --env=dev -- node scripts/sentry-issues.mjs",
    "db:backup": "infisical run --env=prod -- node scripts/db-backup.mjs",
    "db:verify-restore": "node scripts/db-verify-restore.mjs",
    "db:selftest": "node scripts/db-selftest.mjs"
  },
  "devDependencies": {
    "lint-staged": "^17.0.8",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "dotenv": "^16.4.5"
  }
}
