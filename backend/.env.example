SUPABASE_URL=https://example.supabase.co
SUPABASE_SERVICE_KEY=replace-me
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
FRONTEND_URL=http://localhost:5173
PORT=3001

# UCI Sheet - authoritative source.
# GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/<sheet-id>/export?format=csv

# Discord DM routing (#203 verifikations-infrastruktur).
#   webhook       — ægte Discord DM via bot (default for prod)
#   stdout        — log JSON til console; ingen Discord-call (suppress for local dev)
#   test-channel  — embed til DISCORD_TEST_CHANNEL_WEBHOOK_URL (staging-aggregat)
# Test-konti (teams.is_test_account=true) tvinger ALTID stdout uanset env-værdi.
DISCORD_DM_TARGET=webhook
# DISCORD_TEST_CHANNEL_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Race v3 provably-fair seed-salt (#2351). Sæt KUN i prod via Infisical/Railway —
# ALDRIG i en committed .env. Tom/unset = salt inaktiv (legacy usaltede seeds).
# Bump _VERSION ved rotation af salten.
RACE_ENGINE_SEED_SALT=changeme
RACE_ENGINE_SEED_SALT_VERSION=1
