{
  "name": "cycling-zone-manager-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "infisical run --env=dev --recursive -- node --import ./instrument.mjs --watch server.js",
    "dev:envfile": "node --import ./instrument.mjs --watch server.js",
    "start": "node --import ./instrument.mjs server.js",
    "seed:uci-race-points": "node scripts/seedUciMenRacePoints.js",
    "economy:baseline": "node scripts/economyBaselineSimulation.js",
    "season:end:verify-repair": "node scripts/verifySeasonEndRepair.js",
    "board:repair-members-after-dna": "node scripts/repairBoardMembersAfterDna.js",
    "test": "node --test --import ./test-setup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown ."
  },
  "dependencies": {
    "@sentry/node": "^10.55.0",
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.5.2",
    "fast-xml-parser": "^5.7.0",
    "helmet": "^8.2.0",
    "multer": "^2.1.1",
    "node-fetch": "^3.3.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.6",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3"
  },
  "overrides": {
    "qs": "^6.15.2",
    "uuid": "^11.1.1"
  }
}
