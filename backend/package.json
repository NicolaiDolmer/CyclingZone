{
  "name": "cycling-zone-manager-backend",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "scripts": {
    "dev": "infisical run --env=dev --recursive -- node --import ./instrument.mjs --watch server.js",
    "dev:envfile": "node --import ./instrument.mjs --watch server.js",
    "start": "node --import ./instrument.mjs server.js",
    "seed:uci-race-points": "node scripts/seedUciMenRacePoints.js",
    "economy:baseline": "node scripts/economyBaselineSimulation.js",
    "economy:moneysupply": "node scripts/moneySupplyScorecard.js",
    "sim:contracts": "node scripts/economyContractSimulation.js --markdown",
    "sim:academy": "node scripts/academyEconomySimulation.js --markdown",
    "gates:mutation-audit": "node scripts/gateMutationAudit.js",
    "audit:reset-fk": "node scripts/audit-reset-fk-coverage.js",
    "race:gate": "node scripts/raceGate.js --seeds=2026,7,42",
    "race:competitions": "node scripts/raceCompetitionScorecard.js --seeds=2026,7,42 --enforce",
    "race:gate:condition": "node scripts/simulateSeasonDryRun.js --enforce-targets --enforce-liveness --no-html --seed=2026 --condition=random",
    "race:gate:roles": "node scripts/simulateSeasonDryRun.js --enforce-targets --enforce-liveness --no-html --seed=2026 --roles",
    "peak:gate": "node scripts/simulatePeakCouplingDryRun.js --population=scripts/baselines/population-snapshot-2026-07-11.json --seeds=2026,7,42 --enforce",
    "training:gate": "node scripts/previewDailyTraining.js --seasons=12 --count=400 --seed=2026 --enforce-targets",
    "balance:check": "node scripts/balanceBaseline.js --check",
    "balance:baseline": "node scripts/balanceBaseline.js --write",
    "season:end:verify-repair": "node scripts/verifySeasonEndRepair.js",
    "board:repair-members-after-dna": "node scripts/repairBoardMembersAfterDna.js",
    "test": "node --test --import ./test-setup.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown ."
  },
  "dependencies": {
    "@sentry/node": "^10.66.0",
    "@supabase/supabase-js": "^2.110.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "express-rate-limit": "^8.6.0",
    "fast-xml-parser": "^5.10.1",
    "helmet": "^8.3.0",
    "multer": "^2.2.0",
    "node-fetch": "^3.3.2",
    "resend": "^6.17.2",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  },
  "overrides": {
    "qs": "^6.15.2",
    "uuid": "^11.1.1"
  }
}
