# Copy this file to .codex.local/supabase-readonly.env and fill in the values.
# .codex.local is gitignored. Never commit real credentials.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Preferred: a project-scoped read-only key/token for AI inspection.
# Avoid service_role for routine probes.
SUPABASE_READONLY_KEY=PASTE_READ_ONLY_KEY_HERE

# Optional escape hatch for one-off local inspections only.
# Leave unset by default.
# ALLOW_SUPABASE_SERVICE_KEY_FOR_AI_PROBES=1
