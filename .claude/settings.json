{
  "enabledPlugins": {
    "product-management@claude-plugins-official": false,
    "marketing@claude-plugins-official": false,
    "design@claude-plugins-official": false,
    "productivity@claude-plugins-official": false,
    "code-modernization@claude-plugins-official": false,
    "vercel@claude-plugins-official": false
  },
  "permissions": {
    "additionalDirectories": [
      "../CyclingZone-worktrees/"
    ],
    "allow": [
      "Bash(git *)",
      "WebSearch",
      "Write",
      "Edit",
      "NotebookEdit",
      "Bash(node --test)",
      "Bash(node --test *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh label *)",
      "Bash(gh api *)",
      "Bash(gh run *)",
      "Bash(gh workflow *)",
      "Bash(gh auth *)",
      "Bash(pwsh -File scripts/verify-deploy.ps1)",
      "Bash(pwsh -File scripts/verify-deploy.ps1 *)",
      "Bash(pwsh -File scripts/agent-doctor.ps1)",
      "Bash(curl -s *)",
      "Bash(curl -sL *)",
      "Bash(curl -sI *)",
      "PowerShell(gh issue *)",
      "PowerShell(gh pr *)",
      "PowerShell(gh label *)",
      "PowerShell(gh api *)",
      "PowerShell(gh run *)",
      "PowerShell(gh workflow *)",
      "WebSearch",
      "mcp__ccd_session_mgmt__search_session_transcripts",
      "mcp__discord__discord_login",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__list_branches",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__issue_read",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__issue_write",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__list_issues",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__search_issues",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__add_issue_comment",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__sub_issue_write",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__get_label",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__pull_request_read",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__list_pull_requests",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__create_pull_request",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__update_pull_request",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__merge_pull_request",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__get_file_contents",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__list_commits",
      "mcp__392d630e-5e88-4afd-9c53-0a45062c42af__get_commit",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__list_projects",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__apply_migration",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__execute_sql",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__list_tables",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__list_migrations",
      "mcp__0447176e-dd14-40fa-aa2c-4d5692a6a8af__generate_typescript_types",
      "mcp__dba1ab87-9334-4be3-b3cf-b638c78f62d6__list_deployments",
      "mcp__dba1ab87-9334-4be3-b3cf-b638c78f62d6__get_deployment",
      "mcp__dba1ab87-9334-4be3-b3cf-b638c78f62d6__list_projects",
      "mcp__dba1ab87-9334-4be3-b3cf-b638c78f62d6__get_project"
    ],
    "deny": [
      "Write(docs/archive/**)",
      "Edit(docs/archive/**)",
      "NotebookEdit(docs/archive/**)",
      "Write(./docs/archive/**)",
      "Edit(./docs/archive/**)",
      "NotebookEdit(./docs/archive/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/session-prefetch-issue.sh",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/ensure-scheduled-tasks.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/setup-worktree-if-needed.sh",
            "timeout": 60
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-dangerous-secret-commands.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/lint-gh-issue.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/check-ci-before-push.sh"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check-now-md-edit.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/block-archived-edit.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check-now-md-edit.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/block-archived-edit.sh"
          }
        ]
      },
      {
        "matcher": "NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check-now-md-edit.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/block-archived-edit.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sanitize-secrets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sanitize-secrets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sanitize-secrets.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read|Write|Edit|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sanitize-secrets.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check-now-md.sh"
          }
        ]
      }
    ]
  }
}
